generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Exhibit {
  id          String   @id
  name        String
  subtitle    String
  category    String
  description String
  effects     String[]
  warning     String?
  positionX   Float
  positionY   Float
  positionZ   Float
  cabinetId   String
  audioText   String
  waveform    Int[]
  inspectInfo String?
  scale       Float    @default(1.0)
  modelUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Poster {
  id          String   @id
  title       String
  subtitle    String
  description String
  positionX   Float
  positionY   Float
  positionZ   Float
  rotationX   Float
  rotationY   Float
  rotationZ   Float
  impactText  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TiktokVideo {
  id        String   @id
  title     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
